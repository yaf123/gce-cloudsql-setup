# =============================================================================
# GCE + Cloud SQL セットアップ 環境変数
# =============================================================================
# このファイルを .env にコピーして、実際の値を記入してください
#   cp .env.example .env
#   vi .env
# =============================================================================

# GCPプロジェクトID（必須）
GCP_PROJECT_ID=your-gcp-project-id

# プロジェクト名（リソース名のプレフィックスに使用）
PROJECT_NAME=myapp

# リージョン・ゾーン
GCP_REGION=asia-northeast1
GCP_ZONE=asia-northeast1-a

# ドメイン（HTTPS有効化時に設定、不要なら空）
DOMAIN=

# tfstate用GCSバケット名（グローバルで一意にすること）
TFSTATE_BUCKET=${PROJECT_NAME}-terraform-state

# DB設定
DB_NAME=${PROJECT_NAME}
DB_USER=${PROJECT_NAME}-app
DB_PASSWORD=your-db-password-here
